# ───────────────────────────────────────────────────────────
# iam-rust — environment for docker-compose
# Copy to .env (cd deploy && cp .env.example .env) before `docker compose up`
# ───────────────────────────────────────────────────────────

# Postgres
POSTGRES_USER=app
POSTGRES_PASSWORD=app_secret
POSTGRES_DB=postgres

# Per-service databases (created on first boot)
AUTH_DATABASE_URL=postgres://app:app_secret@postgres:5432/auth_db
USER_DATABASE_URL=postgres://app:app_secret@postgres:5432/user_db

# JWT
JWT_SECRET=change-me-in-production-please-32bytes-min
ACCESS_TOKEN_TTL=900          # seconds (15 min)
REFRESH_TOKEN_TTL=604800      # seconds (7 days)
JWT_ISSUER=iam-auth

# Bootstrap admin (created at auth startup if missing; used by smoke test)
BOOTSTRAP_ADMIN_EMAIL=admin@iam.local
BOOTSTRAP_ADMIN_PASSWORD=admin12345

# Deployment env. Set to "production" to enforce security guards.
APP_ENV=development

# Shared secret the gateway presents to internal services (defense-in-depth).
INTERNAL_SERVICE_TOKEN=dev-internal-token-change-me

# v0.2 Security+ toggles (all optional; defaults keep current behavior)
REQUIRE_EMAIL_VERIFICATION=false   # block login until email verified
LOGIN_MAX_FAILURES=5               # lock account after N failed logins (0 = off)
LOGIN_LOCKOUT_SECONDS=900          # lockout duration
AUDIT_ENABLED=true                 # write sensitive actions to the audit log

# gRPC
AUTH_GRPC_PORT=50051
USER_GRPC_PORT=50052
AUTH_GRPC_ADDR=http://auth:50051
USER_GRPC_ADDR=http://user:50052

# Gateway
GATEWAY_HTTP_PORT=8080

LOG_LEVEL=info
RUST_LOG=info
